<view class="tab-bar">
  <view
    class="tab-bar__item {{current === index ? 'tab-bar__item--active' : ''}}"
    wx:for="{{list}}"
    wx:key="index"
    data-index="{{index}}"
    catchtap="onTabTap"
  >
    <text class="tab-bar__icon">{{current === index ? item.activeIcon : item.icon}}</text>
    <text class="tab-bar__text">{{item.text}}</text>
  </view>
</view>
