.page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 排队头部 */
.queue-header {
  position: relative;
  padding: 40rpx 30rpx 80rpx;
  overflow: hidden;
}

.queue-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 0 0 60rpx 60rpx;
}

.queue-header-content {
  position: relative;
  text-align: center;
}

.queue-doctor {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}

.queue-date {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 排队号 */
.queue-numbers {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin: -50rpx 30rpx 20rpx;
  position: relative;
  z-index: 1;
}

.queue-number-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.queue-number-card--mine {
  background: linear-gradient(135deg, #ede6ff, #f5f0ff);
  border: 2rpx solid var(--primary);
}

.qnc-label {
  font-size: 26rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 8rpx;
}

.queue-number-card--mine .qnc-label {
  color: var(--primary);
  font-weight: 500;
}

.qnc-number {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--primary);
}

.queue-divider {
  display: flex;
  align-items: center;
}

.queue-arrow {
  font-size: 40rpx;
  color: #d1d5db;
  font-weight: 700;
}

/* 等待信息 */
.queue-info {
  display: flex;
  margin: 0 30rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.qi-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.qi-item + .qi-item {
  border-left: 2rpx solid #f3f4f6;
}

.qi-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.qi-label {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 排队指引 */
.card {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 30rpx 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 24rpx;
}

.guide-steps {
  display: flex;
  align-items: center;
  justify-content: center;
}

.guide-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.guide-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #9ca3af;
}

.guide-step--active .guide-dot {
  background: var(--primary);
  color: #fff;
}

.guide-text {
  font-size: 24rpx;
  color: #9ca3af;
  white-space: nowrap;
}

.guide-step--active .guide-text {
  color: var(--primary);
  font-weight: 500;
}

.guide-line {
  width: 80rpx;
  height: 4rpx;
  background: #e5e7eb;
  margin: 0 12rpx;
  margin-bottom: 56rpx;
}

.guide-line--active {
  background: var(--primary);
}

/* 温馨提示 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.5;
}

/* 刷新按钮 */
.refresh-bar {
  padding: 20rpx 30rpx 40rpx;
}

.refresh-bar .btn-primary {
  width: 100%;
}
