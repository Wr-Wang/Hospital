.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 56rpx 40rpx;
  box-sizing: border-box;
}

/* ========= 头部 ========= */
.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
}

.login-logo {
  width: 144rpx;
  height: 144rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  backdrop-filter: blur(6px);
}

.logo-icon {
  font-size: 72rpx;
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  letter-spacing: 4rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 2rpx;
}

/* ========= 登录卡片 ========= */
.login-card {
  width: 100%;
  background: #fff;
  border-radius: 28rpx;
  padding: 44rpx 40rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
}

.login-card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
  text-align: center;
  margin-bottom: 36rpx;
}

/* ========= 提示文字 ========= */
.error-tip {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #ef4444;
  margin-top: 20rpx;
}

/* ========= 底部 ========= */
.login-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: auto;
  padding: 32rpx 0;
}

.login-footer-link {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.login-footer-link:active {
  color: #fff;
}

/* ========= 微信登录按钮 ========= */
.wechat-login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-top: 20rpx;
  padding: 0;
  line-height: 96rpx;
  box-shadow: 0 6rpx 24rpx rgba(7, 193, 96, 0.35);
  letter-spacing: 4rpx;
}
.wechat-login-btn::after { border: none; }
.wechat-login-btn:active {
  opacity: 0.92;
  transform: scale(0.97);
}

.login-desc {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 20rpx;
}

/* ========= 姓名输入弹窗 ========= */
.patient-picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.patient-picker {
  width: 600rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 44rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
}

.picker-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
  text-align: center;
  margin-bottom: 12rpx;
}

.picker-desc {
  display: block;
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  margin-bottom: 32rpx;
}

.name-input {
  width: 100%;
  height: 88rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 18rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1f2937;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  padding: 0;
}
.confirm-btn::after { border: none; }
.confirm-btn:active {
  opacity: 0.92;
  transform: scale(0.97);
}
