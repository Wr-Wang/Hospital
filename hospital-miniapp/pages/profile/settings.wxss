.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.menu-section {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
}

.menu-item + .menu-item {
  border-top: 2rpx solid #f9fafb;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  width: 36rpx;
  text-align: center;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
}

.menu-value {
  font-size: 26rpx;
  color: #9ca3af;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #d1d5db;
}

.logout-bar {
  padding: 40rpx 30rpx;
}

.logout-btn {
  width: 100%;
  padding: 28rpx 0;
  background: #fff;
  border: 2rpx solid #ef4444;
  border-radius: 16rpx;
  color: #ef4444;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  background: #fef2f2;
}
