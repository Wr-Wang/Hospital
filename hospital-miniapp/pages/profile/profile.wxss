.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 30rpx;
}

/* ========= 用户信息头部 ========= */
.profile-header {
  position: relative;
  padding-bottom: 40rpx;
}

.profile-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 340rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 80rpx 80rpx;
}

.profile-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 70rpx;
}

.profile-avatar {
  width: 130rpx;
  height: 130rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid rgba(255, 255, 255, 0.35);
  margin-bottom: 18rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.avatar-emoji {
  font-size: 60rpx;
  color: #fff;
  font-weight: 700;
}

.profile-info-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.profile-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  padding: 10rpx 0;
}

.profile-arrow {
  position: absolute;
  right: -60rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 300;
}

/* ========= 快捷统计 ========= */
.quick-stats {
  display: flex;
  align-items: center;
  margin: -30rpx 30rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 10rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 2;
}

.qs-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.qs-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-bottom: 4rpx;
}
.qs-icon--pending { background: #ede6ff; }
.qs-icon--done { background: #dcfce7; }
.qs-icon--users { background: #dbeafe; }

.qs-divider {
  width: 2rpx;
  height: 60rpx;
  background: #f3f4f6;
}

.qs-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--primary);
}

.qs-label {
  font-size: 24rpx;
  color: #9ca3af;
}

/* ========= 功能菜单 ========= */
.menu-section {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 30rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.menu-section-header {
  font-size: 26rpx;
  font-weight: 600;
  color: #9ca3af;
  padding: 28rpx 30rpx 12rpx;
  letter-spacing: 2rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 26rpx 30rpx;
}

.menu-item:active {
  background: #f9fafb;
}

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-icon-text {
  font-size: 32rpx;
}

.menu-icon--p1 { background: #ede6ff; }
.menu-icon--p2 { background: #dbeafe; }
.menu-icon--p3 { background: #dcfce7; }
.menu-icon--p4 { background: #fef3c7; }
.menu-icon--p5 { background: #f3f4f6; }
.menu-icon--p6 { background: #fee2e2; }

.menu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2937;
}

.menu-desc {
  font-size: 24rpx;
  color: #9ca3af;
}

.menu-label--danger {
  color: #ef4444;
}

.menu-arrow {
  font-size: 34rpx;
  color: #d1d5db;
  margin-left: 12rpx;
}

.bottom-spacer {
  height: 160rpx;
}
