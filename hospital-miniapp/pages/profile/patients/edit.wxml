<view class="page">
  <scroll-view class="form-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="form-card">
      <view class="form-item">
        <text class="form-label">姓名 <text class="required">*</text></text>
        <view class="input-wrap">
          <text class="input-icon">👤</text>
          <input class="form-input" placeholder="请输入就诊人姓名" value="{{form.name}}" bindinput="onInput" data-field="name" maxlength="20" />
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">性别 <text class="required">*</text></text>
        <view class="radio-group">
          <view class="radio-option {{form.gender === 1 ? 'radio-option--active' : ''}}" bindtap="setGender" data-value="1">
            <text>男</text>
          </view>
          <view class="radio-option {{form.gender === 2 ? 'radio-option--active' : ''}}" bindtap="setGender" data-value="2">
            <text>女</text>
          </view>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">身份证号 <text class="required">*</text></text>
        <view class="input-wrap">
          <text class="input-icon">🪪</text>
          <input class="form-input" placeholder="请输入18位身份证号" value="{{form.idCard}}" bindinput="onInput" data-field="idCard" maxlength="18" type="idcard" />
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">手机号 <text class="required">*</text></text>
        <view class="input-wrap">
          <text class="input-icon">📱</text>
          <input class="form-input" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" maxlength="11" type="number" />
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">关系</text>
        <picker mode="selector" range="{{relationOptions}}" value="{{form.relationIndex}}" bindchange="onRelationChange">
          <view class="input-wrap form-picker">
            <text class="input-icon">👨‍👩‍👧‍👦</text>
            <text wx:if="{{form.relation}}" class="picker-value">{{form.relation}}</text>
            <text wx:else class="picker-placeholder">请选择与就诊人的关系</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button class="btn-primary" bindtap="savePatient">保存</button>
    <button wx:if="{{isEdit}}" class="btn-danger" bindtap="deletePatient">删除就诊人</button>
  </view>
</view>
