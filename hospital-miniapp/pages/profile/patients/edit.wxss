.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 240rpx;
}

.form-scroll {
  flex: 1;
}

.form-card {
  background: #fff;
  border-radius: 28rpx;
  margin: 24rpx 30rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  display: block;
  margin-bottom: 12rpx;
}

.required {
  color: #ef4444;
}

/* 输入框容器 */
.input-wrap {
  display: flex;
  align-items: center;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 18rpx;
  padding: 0 28rpx;
  transition: border-color 0.2s;
}

.input-wrap:focus-within {
  border-color: var(--primary);
  background: #fff;
}

.input-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #1f2937;
  background: transparent;
  border: none;
  outline: none;
  padding: 0;
}

.form-input::placeholder {
  color: #9ca3af;
  font-size: 26rpx;
}

/* 性别选择 */
.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio-option {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 18rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.radio-option--active {
  background: #ede6ff;
  border-color: var(--primary);
  color: var(--primary);
  font-weight: 600;
}

/* 选择器 */
.form-picker {
  padding-right: 0;
}

.picker-value, .picker-placeholder {
  flex: 1;
  font-size: 28rpx;
  line-height: 88rpx;
}

.picker-value {
  color: #1f2937;
}

.picker-placeholder {
  color: #9ca3af;
}

.picker-arrow {
  font-size: 34rpx;
  color: #d1d5db;
  padding: 0 20rpx;
  flex-shrink: 0;
  line-height: 88rpx;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bottom-bar .btn-primary {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.bottom-bar .btn-danger {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 48rpx;
  font-size: 30rpx;
  padding: 0;
  background: #fff;
  color: #ef4444;
  border: 2rpx solid #fca5a5;
  margin-top: 16rpx;
}

.bottom-bar .btn-danger::after {
  border: none;
}
