.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

.success-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.success-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.success-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.card {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f9fafb;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #6b7280;
}

.info-value {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
  text-align: right;
  max-width: 60%;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.5;
}

.action-buttons {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}
.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: #fff;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}
.btn-secondary::after {
  border: none;
}

.btn-secondary:active {
  background: #ede6ff;
}
