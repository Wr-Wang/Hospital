.page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 院区切换 */
.campus-tabs {
  display: flex;
  background: #fff;
  padding: 0 30rpx;
  border-bottom: 2rpx solid #e5e7eb;
  position: sticky;
  top: 0;
  z-index: 10;
}

.campus-tab {
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #6b7280;
  position: relative;
  font-weight: 500;
}

.campus-tab--active {
  color: var(--primary);
  font-weight: 600;
}

.campus-tab--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30rpx;
  right: 30rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

/* 搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 20rpx 30rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
}

.search-placeholder {
  color: #9ca3af;
}

/* 科室列表 */
.dept-list {
  padding: 0 30rpx;
  max-height: calc(100vh - 200rpx);
}

.dept-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.dept-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  background: #ede6ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.dept-icon {
  font-size: 36rpx;
}

.dept-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.dept-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.dept-desc {
  font-size: 24rpx;
  color: #9ca3af;
}

.dept-arrow {
  font-size: 36rpx;
  color: #d1d5db;
  margin-left: 12rpx;
}
