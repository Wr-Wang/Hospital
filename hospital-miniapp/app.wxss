/* 全局样式 - 品牌色：#863bff */
page {
  --primary: #863bff;
  --primary-dark: #6a1cf5;
  --primary-light: #ede6ff;
  --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --success: #22c55e;
  --warning: #f59e0b;
  --danger: #ef4444;
  --info: #3b82f6;
  --text-primary: #1f2937;
  --text-secondary: #6b7280;
  --text-light: #9ca3af;
  --bg-page: #f5f5f5;
  --bg-card: #ffffff;
  --border: #e5e7eb;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 20rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);

  box-sizing: border-box;
  background-color: var(--bg-page);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
  --safe-area-inset-bottom: env(safe-area-inset-bottom, 0px);
}

/* 通用卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: var(--shadow-sm);
}

/* 主按钮 */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  padding: 0 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  transition: opacity 0.2s;
}
.btn-primary::after {
  border: none;
}
.btn-primary:active {
  opacity: 0.8;
}
.btn-primary--disabled {
  background: #c4b5fd;
}

/* 页面标题 */
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  padding: 30rpx 30rpx 20rpx;
  color: var(--text-primary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: var(--text-light);
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: var(--border);
  margin: 0 30rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}
.tag--primary {
  background: var(--primary-light);
  color: var(--primary);
}
.tag--success {
  background: #dcfce7;
  color: #16a34a;
}
.tag--warning {
  background: #fef3c7;
  color: #d97706;
}
.tag--danger {
  background: #fee2e2;
  color: #dc2626;
}
