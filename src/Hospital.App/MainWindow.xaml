<Window x:Class="Hospital.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="医院管理系统"
        Height="720"
        Width="1200"
        MinHeight="480"
        MinWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12,8"
                Background="#F3F4F6"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text="{Binding AppContext.CampusName, StringFormat={}{0} — 医院管理系统}" />
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="#374151"
                           Text="{Binding AppContext.CurrentUserDisplayName}" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#E5E7EB"
                    BorderThickness="0,0,1,0"
                    Background="#FAFAFA">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl Margin="8"
                                  ItemsSource="{Binding MenuItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,4,0,0"
                                        Padding="10,8"
                                        HorizontalContentAlignment="Left"
                                        Content="{Binding Title}"
                                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <ContentControl x:Name="ShellContentHost"
                            Grid.Column="1"
                            Margin="0" />
        </Grid>
    </Grid>
</Window>
