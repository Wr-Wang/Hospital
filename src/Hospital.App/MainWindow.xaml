<Window x:Class="Hospital.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        MinWidth="1024"
        MinHeight="600"
        Title="医院管理系统"
        FontFamily="Microsoft YaHei, SimHei, sans-serif"
        Background="#F0F2F5">

    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBg" Color="#1E40AF" />
        <SolidColorBrush x:Key="NavItemBgSelected" Color="#2563EB" />
        <SolidColorBrush x:Key="NavItemBgHover" Color="#2563EB" />
        <SolidColorBrush x:Key="NavText" Color="#E0E7FF" />
        <SolidColorBrush x:Key="NavTextSelected" Color="#FFFFFF" />

        <Style x:Key="NavListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="8,2" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="itemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}"
                                Margin="{TemplateBinding Margin}"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              SnapsToDevicePixels="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="{StaticResource NavItemBgHover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="{StaticResource NavItemBgSelected}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ==================== Sidebar ==================== -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- User profile section -->
                <Border Grid.Row="0"
                        Padding="20,24,20,20"
                        BorderBrush="#2563EB"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <Border Width="56"
                                Height="56"
                                Background="#3B82F6"
                                CornerRadius="28"
                                HorizontalAlignment="Center">
                            <TextBlock FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#FFFFFF"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding AppContext.CurrentUserDisplayName, StringFormat={}{0}}" />
                        </Border>
                        <TextBlock Margin="0,12,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF"
                                   Text="{Binding AppContext.CurrentUserDisplayName}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="#93C5FD"
                                   Text="{Binding AppContext.CampusName}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Navigation items (ListBox for built-in selection) -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,8,0,0">
                    <ListBox ItemsSource="{Binding MenuItems}"
                             SelectedItem="{Binding SelectedMenuItem, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource NavListBoxItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               DockPanel.Dock="Left" />
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="15"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"
                                               DockPanel.Dock="Left">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource NavText}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource NavTextSelected}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- Logout button -->
                <Border Grid.Row="2"
                        Padding="16,12"
                        BorderBrush="#2563EB"
                        BorderThickness="0,1,0,0">
                    <Button HorizontalContentAlignment="Left"
                            Padding="16,10"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#93C5FD"
                            FontSize="14"
                            Cursor="Hand"
                            Command="{Binding LogoutCommand}">
                        <DockPanel>
                            <TextBlock Text="⏻"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left" />
                            <TextBlock Text="退出系统"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left" />
                        </DockPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- ==================== Main content area ==================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0"
                    Padding="24,14,24,14"
                    Background="#FFFFFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="#6B7280">
                        <Run Text="{Binding AppContext.CampusName}" />
                        <Run Text="—" />
                        <Run Text="医院管理系统" />
                    </TextBlock>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal">
                        <Border Background="#EEF2FF"
                                Padding="8,4,10,4"
                                CornerRadius="4"
                                Margin="0,0,12,0">
                            <TextBlock Text="{Binding AppContext.CurrentUserDisplayName}"
                                       FontSize="13"
                                       Foreground="#2563EB"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Page content -->
            <ContentControl x:Name="ShellContentHost"
                            Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
