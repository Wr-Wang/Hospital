<UserControl x:Class="Hospital.App.Views.EncounterWorkbenchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Hospital.App.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             FontFamily="Microsoft YaHei, SimHei, sans-serif">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- ===== Header ===== -->
            <Border Padding="32,28" CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0EA5E9" Offset="0.0" />
                        <GradientStop Color="#0284C7" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}"
                               Text="门诊医生站" />
                    <TextBlock Margin="0,8,0,0" FontSize="14"
                               Foreground="{StaticResource BlueAccentBrush}"
                               Text="病历书写 · 诊断开立 · 处方开立 · 检验检查申请" />
                </StackPanel>
            </Border>

            <!-- ===== Error Banner ===== -->
            <Border Margin="0,16,0,0"
                    Style="{StaticResource ErrorBannerStyle}"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="13" Foreground="{StaticResource Red700Brush}"
                           TextWrapping="Wrap" />
            </Border>

            <!-- ===== Selected Patient Info ===== -->
            <Border Margin="0,12,0,0" Padding="16,10" CornerRadius="6"
                    Background="{StaticResource BlueSubtleBrush}"
                    Visibility="{Binding SelectedPatientInfo, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource BluePrimaryBrush}"
                               Text="{Binding SelectedPatientInfo}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="24,0,0,0">
                        <Button Content="开始接诊" Height="32" Padding="16,0" Margin="0,0,8,0"
                                FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding StartConsultationCommand}" />
                        <Button Content="完成接诊" Height="32" Padding="16,0"
                                FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CompleteConsultationCommand}" />
                    </StackPanel>
                    <Button Grid.Column="3" Content="刷新队列" Height="32" Padding="12,0" Margin="12,0,0,0"
                            FontSize="13" Cursor="Hand"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding LoadQueueCommand}" />
                </Grid>
            </Border>

            <!-- ===== TabControl ===== -->
            <Border Margin="0,16,0,0" Padding="0" CornerRadius="10"
                    Background="{StaticResource WhiteBrush}">
                <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                            Padding="0" Margin="0"
                            Background="Transparent"
                            BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabPanel">
                            <Setter Property="Background" Value="{StaticResource Gray50Brush}" />
                        </Style>
                    </TabControl.Resources>

                    <!-- ===== Tab 1: 患者队列 ===== -->
                    <TabItem Header="① 患者队列">
                        <TabItem.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="① 患者队列" FontSize="14" FontWeight="SemiBold" Padding="16,10" />
                            </DataTemplate>
                        </TabItem.HeaderTemplate>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
                            <StackPanel>
                                <TextBlock FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource Gray900Brush}"
                                           Text="{Binding QueueItems.Count, StringFormat='待诊队列（{0} 人）'}" />

                                <ItemsControl ItemsSource="{Binding QueueItems}" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14,10" Margin="0,0,0,4" CornerRadius="6"
                                                    Background="{StaticResource Gray50Brush}"
                                                    Cursor="Hand">
                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftClick"
                                                                  Command="{Binding DataContext.SelectPatientCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  CommandParameter="{Binding}" />
                                                </Border.InputBindings>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" FontSize="18" FontWeight="Bold"
                                                               Foreground="{StaticResource BluePrimaryBrush}"
                                                               Text="{Binding QueueNumber, StringFormat='#{0}'}"
                                                               VerticalAlignment="Center" Margin="0,0,12,0" />
                                                    <TextBlock Grid.Column="1" FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{StaticResource Gray900Brush}"
                                                               Text="{Binding PatientName}"
                                                               VerticalAlignment="Center" Margin="0,0,12,0" />
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock FontSize="12"
                                                                   Foreground="{StaticResource Gray500Brush}"
                                                                   Text="{Binding SlotName}" />
                                                    </StackPanel>
                                                    <Border Grid.Column="3" Padding="8,4" CornerRadius="4"
                                                            Background="{StaticResource BlueSubtleBrush}"
                                                            VerticalAlignment="Center" Margin="0,0,8,0">
                                                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource BluePrimaryBrush}"
                                                                   Text="{Binding Status}" />
                                                    </Border>
                                                    <TextBlock Grid.Column="4" FontSize="12"
                                                               Foreground="{StaticResource Gray400Brush}"
                                                               Text="{Binding RegisterTime}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Tab 2: 病历书写 ===== -->
                    <TabItem Header="② 病历书写">
                        <TabItem.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="② 病历书写" FontSize="14" FontWeight="SemiBold" Padding="16,10" />
                            </DataTemplate>
                        </TabItem.HeaderTemplate>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource Gray900Brush}"
                                               Text="病历书写" />
                                    <TextBlock Grid.Column="1" FontSize="13" Foreground="{StaticResource Gray500Brush}"
                                               Text="{Binding RecordStatusText, StringFormat='状态: {0}'}" />
                                </Grid>

                                <TextBlock Margin="0,16,0,0" Text="主诉" FontSize="13" FontWeight="Medium"
                                           Foreground="{StaticResource Gray700Brush}" />
                                <TextBox Margin="0,4,0,0" Height="36" Padding="8,0"
                                         Text="{Binding ChiefComplaint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}" />

                                <TextBlock Margin="0,12,0,0" Text="现病史" FontSize="13" FontWeight="Medium"
                                           Foreground="{StaticResource Gray700Brush}" />
                                <TextBox Margin="0,4,0,0" Height="72" Padding="8,4"
                                         Text="{Binding PresentIllness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         Style="{StaticResource FormTextBoxStyle}" />

                                <TextBlock Margin="0,12,0,0" Text="既往史" FontSize="13" FontWeight="Medium"
                                           Foreground="{StaticResource Gray700Brush}" />
                                <TextBox Margin="0,4,0,0" Height="60" Padding="8,4"
                                         Text="{Binding PastHistory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         Style="{StaticResource FormTextBoxStyle}" />

                                <TextBlock Margin="0,12,0,0" Text="体格检查" FontSize="13" FontWeight="Medium"
                                           Foreground="{StaticResource Gray700Brush}" />
                                <TextBox Margin="0,4,0,0" Height="60" Padding="8,4"
                                         Text="{Binding PhysicalExam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         Style="{StaticResource FormTextBoxStyle}" />

                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                    <Button Content="保存草稿" Width="120" Height="36" Margin="0,0,12,0"
                                            FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding SaveMedicalRecordCommand}" />
                                    <Button Content="提交终稿" Width="120" Height="36"
                                            FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding SubmitMedicalRecordCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Tab 3: 诊断开立 ===== -->
                    <TabItem Header="③ 诊断开立">
                        <TabItem.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="③ 诊断开立" FontSize="14" FontWeight="SemiBold" Padding="16,10" />
                            </DataTemplate>
                        </TabItem.HeaderTemplate>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
                            <StackPanel>
                                <TextBlock FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource Gray900Brush}"
                                           Text="诊断列表" />

                                <ItemsControl ItemsSource="{Binding Diagnoses}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,8" Margin="0,0,0,4" CornerRadius="6"
                                                    Background="{StaticResource Gray50Brush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Padding="8,3" CornerRadius="4"
                                                            Background="{StaticResource BlueLightBrush}"
                                                            Margin="0,0,12,0">
                                                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource WhiteBrush}"
                                                                   Text="{Binding DiagnosisType}" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Gray900Brush}"
                                                                   Text="{Binding Description}" />
                                                        <TextBlock FontSize="12"
                                                                   Foreground="{StaticResource Gray500Brush}"
                                                                   Text="{Binding IcdCode}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="2" Content="删除" Width="60" Height="28"
                                                            FontSize="12" Cursor="Hand"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding DataContext.RemoveDiagnosisCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding Id}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Margin="0,16,0,0" Padding="16,14" CornerRadius="8"
                                        Background="{StaticResource Gray50Brush}">
                                    <StackPanel>
                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Gray900Brush}"
                                                   Text="新增诊断" />
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="诊断类型"
                                                       FontSize="13" Foreground="{StaticResource Gray700Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,8" />
                                            <ComboBox Grid.Row="0" Grid.Column="1" Height="36" MinWidth="140"
                                                      ItemsSource="{Binding DiagnosisTypeOptions}"
                                                      SelectedItem="{Binding NewDiagnosisType, Mode=TwoWay}"
                                                      Margin="0,0,16,8" HorizontalAlignment="Left" />

                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="ICD 编码"
                                                       FontSize="13" Foreground="{StaticResource Gray700Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,8" />
                                            <TextBox Grid.Row="0" Grid.Column="3" Height="36" Padding="8,0"
                                                     Text="{Binding NewIcdCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,8"
                                                     Style="{StaticResource FormTextBoxStyle}" />

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="诊断描述"
                                                       FontSize="13" Foreground="{StaticResource Gray700Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Height="36"
                                                     Padding="8,0"
                                                     Text="{Binding NewDiagnosisDesc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FormTextBoxStyle}" />
                                        </Grid>
                                        <Button Content="添加诊断" Width="120" Height="34" Margin="0,12,0,0"
                                                FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                HorizontalAlignment="Left"
                                                Command="{Binding AddDiagnosisCommand}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Tab 4: 处方开立 ===== -->
                    <TabItem Header="④ 处方开立">
                        <TabItem.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="④ 处方开立" FontSize="14" FontWeight="SemiBold" Padding="16,10" />
                            </DataTemplate>
                        </TabItem.HeaderTemplate>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
                            <StackPanel>
                                <TextBlock FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource Gray900Brush}"
                                           Text="已开处方" />

                                <ItemsControl ItemsSource="{Binding Prescriptions}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14,10" Margin="0,0,0,6" CornerRadius="6"
                                                    Background="{StaticResource Gray50Brush}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource BluePrimaryBrush}"
                                                                   Text="{Binding Status}" Margin="0,0,12,0" />
                                                        <TextBlock Grid.Column="2" FontSize="12"
                                                                   Foreground="{StaticResource Gray400Brush}"
                                                                   Text="{Binding Id, StringFormat='处方 #{0}'}" />
                                                    </Grid>
                                                    <ItemsControl ItemsSource="{Binding Items}" Margin="0,6,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Padding="8,6" Margin="0,0,0,2" CornerRadius="4"
                                                                        Background="{StaticResource WhiteBrush}">
                                                                    <TextBlock FontSize="13"
                                                                               Foreground="{StaticResource Gray700Brush}">
                                                                        <Run Text="{Binding DrugName}" FontWeight="SemiBold" />
                                                                        <Run Text="{Binding Spec}" />
                                                                        <Run Text=" | " />
                                                                        <Run Text="{Binding Dosage}" />
                                                                        <Run Text="{Binding Freq}" />
                                                                        <Run Text=" | " />
                                                                        <Run Text="{Binding Qty, StringFormat='{}{0} 剂'}" />
                                                                    </TextBlock>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- New Prescription Form -->
                                <Border Margin="0,16,0,0" Padding="16,14" CornerRadius="8"
                                        Background="{StaticResource Gray50Brush}">
                                    <StackPanel>
                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Gray900Brush}" Text="开立新处方" />

                                        <ItemsControl ItemsSource="{Binding NewPrescriptionItems}" Margin="0,12,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10,8" Margin="0,0,0,6" CornerRadius="6"
                                                            Background="{StaticResource WhiteBrush}">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Grid Grid.Row="0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox Grid.Column="0" Height="32" Padding="6,0" Margin="0,0,6,0"
                                                                         Text="{Binding DrugName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource FormTextBoxStyle}" />
                                                                <TextBox Grid.Column="1" Height="32" Padding="6,0" Margin="0,0,6,0"
                                                                         Text="{Binding Spec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource FormTextBoxStyle}" />
                                                                <TextBox Grid.Column="2" Height="32" Padding="6,0" Margin="0,0,6,0"
                                                                         Text="{Binding Form, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource FormTextBoxStyle}" />
                                                                <Button Grid.Column="3" Content="×" Width="28" Height="28"
                                                                        FontSize="14" Cursor="Hand"
                                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                                        Command="{Binding DataContext.RemovePrescriptionItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}" />
                                                            </Grid>
                                                            <Grid Grid.Row="1" Margin="0,6,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox Grid.Column="0" Height="32" Padding="6,0" Margin="0,0,6,0"
                                                                         Text="{Binding Freq, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource FormTextBoxStyle}" />
                                                                <TextBox Grid.Column="1" Height="32" Padding="6,0" Margin="0,0,6,0"
                                                                         Text="{Binding Dosage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource FormTextBoxStyle}" />
                                                                <TextBox Grid.Column="2" Height="32" Padding="6,0" Margin="0,0,6,0"
                                                                         Text="{Binding Duration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0}"
                                                                         Style="{StaticResource FormTextBoxStyle}" />
                                                                <TextBox Grid.Column="3" Height="32" Padding="6,0"
                                                                         Text="{Binding Qty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0}"
                                                                         Style="{StaticResource FormTextBoxStyle}" />
                                                            </Grid>
                                                            <Grid Grid.Row="2" Margin="0,4,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="备注" FontSize="11"
                                                                           Foreground="{StaticResource Gray500Brush}"
                                                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                                                <TextBox Grid.Column="1" Height="28" Padding="4,0"
                                                                         Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource FormTextBoxStyle}" />
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="+ 添加药品" Height="34" Padding="16,0" Margin="0,0,12,0"
                                                    FontSize="13" Cursor="Hand"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding AddPrescriptionItemCommand}" />
                                            <Button Content="开立处方" Width="120" Height="34"
                                                    FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Command="{Binding CreatePrescriptionCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Tab 5: 检验检查 ===== -->
                    <TabItem Header="⑤ 检验检查">
                        <TabItem.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="⑤ 检验检查" FontSize="14" FontWeight="SemiBold" Padding="16,10" />
                            </DataTemplate>
                        </TabItem.HeaderTemplate>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
                            <StackPanel>
                                <TextBlock FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource Gray900Brush}" Text="检验申请" />

                                <ItemsControl ItemsSource="{Binding LabOrders}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,8" Margin="0,0,0,4" CornerRadius="6"
                                                    Background="{StaticResource Gray50Brush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Gray900Brush}"
                                                                   Text="{Binding ItemName}" />
                                                        <TextBlock FontSize="12"
                                                                   Foreground="{StaticResource Gray500Brush}"
                                                                   Text="{Binding ItemCode}" />
                                                    </StackPanel>
                                                    <Border Grid.Column="1" Padding="8,4" CornerRadius="4"
                                                            Background="{StaticResource BlueSubtleBrush}"
                                                            VerticalAlignment="Center" Margin="0,0,8,0">
                                                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource BluePrimaryBrush}"
                                                                   Text="{Binding Status}" />
                                                    </Border>
                                                    <Button Grid.Column="2" Content="取消" Width="60" Height="28"
                                                            FontSize="12" Cursor="Hand"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding DataContext.CancelLabOrderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding Id}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Margin="0,16,0,0" Padding="16,14" CornerRadius="8"
                                        Background="{StaticResource Gray50Brush}">
                                    <StackPanel>
                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Gray900Brush}" Text="新增检验申请" />
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="项目编码" FontSize="13"
                                                       Foreground="{StaticResource Gray700Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBox Grid.Column="1" Height="36" Padding="8,0" Margin="0,0,16,0"
                                                     Text="{Binding NewLabItemCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FormTextBoxStyle}" />
                                            <TextBlock Grid.Column="2" Text="项目名称" FontSize="13"
                                                       Foreground="{StaticResource Gray700Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBox Grid.Column="3" Height="36" Padding="8,0"
                                                     Text="{Binding NewLabItemName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FormTextBoxStyle}" />
                                        </Grid>
                                        <Button Content="添加申请" Width="120" Height="34" Margin="0,12,0,0"
                                                FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                HorizontalAlignment="Left"
                                                Command="{Binding AddLabOrderCommand}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
