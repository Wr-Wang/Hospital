<UserControl x:Class="Hospital.App.Views.PatientBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource BlueSubtleBrush}"
            CornerRadius="8"
            Padding="16,12"
            Margin="0,0,0,16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Avatar -->
            <Border Grid.Column="0"
                    Width="48" Height="48"
                    CornerRadius="24"
                    Background="{StaticResource BluePrimaryBrush}"
                    VerticalAlignment="Center">
                <TextBlock x:Name="AvatarText"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource WhiteBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="?" />
            </Border>
            <!-- Info -->
            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="PatientName"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Gray900Brush}"
                           Text="--" />
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock x:Name="PatientInfo"
                               FontSize="13"
                               Foreground="{StaticResource Gray500Brush}"
                               Text="--" />
                    <TextBlock Margin="12,0,0,0"
                               FontSize="13"
                               Foreground="{StaticResource Gray500Brush}"
                               Text="{Binding ElementName=PatientIdLabel, Path=Text}"
                               x:Name="PatientIdLabel" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
