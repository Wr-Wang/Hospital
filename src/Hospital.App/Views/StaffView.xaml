<UserControl x:Class="Hospital.App.Views.StaffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             FontFamily="Microsoft YaHei, SimHei, sans-serif">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- ===== Header ===== -->
            <Border Padding="32,28" CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#14B8A6" Offset="0.0" />
                        <GradientStop Color="#0D9488" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}"
                               Text="人员档案" />
                    <TextBlock Margin="0,8,0,0" FontSize="14"
                               Foreground="{StaticResource BlueAccentBrush}"
                               Text="维护医护人员档案与执业信息，资质到期自动预警" />
                </StackPanel>
            </Border>

            <!-- ===== Error Banner ===== -->
            <Border Margin="0,16,0,0"
                    Style="{StaticResource ErrorBannerStyle}"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="13" Foreground="{StaticResource Red700Brush}"
                           TextWrapping="Wrap" />
            </Border>

            <!-- ===== Search + Toolbar ===== -->
            <Border Margin="0,16,0,0" Padding="24,16" CornerRadius="10"
                    Background="{StaticResource WhiteBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="科室" FontSize="13" FontWeight="Medium"
                               VerticalAlignment="Center" Margin="0,0,10,0" />
                    <ComboBox Grid.Column="1" MinWidth="140" Height="34" Margin="0,0,16,0"
                              ItemsSource="{Binding Departments}"
                              SelectedItem="{Binding SelectedDept, Mode=TwoWay}"
                              DisplayMemberPath="Name" />
                    <TextBox Grid.Column="2" MinWidth="180" Height="36" Padding="8,0"
                             Text="{Binding Keyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}" />
                    <Button Grid.Column="3" Content="搜索" Width="80" Height="36" Margin="8,0,16,0"
                            FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SearchCommand}" />
                    <Button Grid.Column="5" Content="+ 新建人员" Height="34" Padding="16,0"
                            FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ShowCreateFormCommand}" />
                </Grid>
            </Border>

            <!-- ===== Staff List ===== -->
            <ItemsControl ItemsSource="{Binding StaffList}" Margin="0,4,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14,10" Margin="0,0,0,4" CornerRadius="6"
                                Background="{StaticResource WhiteBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                        Background="{StaticResource BlueLightBrush}" Margin="0,0,12,0">
                                    <TextBlock FontSize="18" Foreground="{StaticResource WhiteBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Text="👤" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource Gray900Brush}"
                                               Text="{Binding Name}" />
                                    <TextBlock Margin="0,2,0,0" FontSize="12"
                                               Foreground="{StaticResource Gray500Brush}">
                                        <Run Text="{Binding Code}" />
                                        <Run Text=" | " />
                                        <Run Text="{Binding LicenseType}" />
                                        <Run Text=" | " />
                                        <Run Text="{Binding LicenseNo}" />
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="2" Padding="6,3" CornerRadius="4"
                                        Background="{StaticResource BlueSubtleBrush}"
                                        VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource BluePrimaryBrush}"
                                               Text="{Binding Gender}" />
                                </Border>
                                <TextBlock Grid.Column="3" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource Green600Brush}"
                                           VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock.Visibility>
                                        <Binding Path="IsActive" Converter="{StaticResource BoolToVisibilityConverter}" />
                                    </TextBlock.Visibility>
                                    正常
                                </TextBlock>
                                <TextBlock Grid.Column="3" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource Red700Brush}"
                                           VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock.Visibility>
                                        <Binding Path="IsActive" Converter="{StaticResource BoolToInverseConverter}" />
                                    </TextBlock.Visibility>
                                    已停用
                                </TextBlock>
                                <Button Grid.Column="4" Content="编辑" Width="60" Height="28"
                                        FontSize="12" Cursor="Hand"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding DataContext.ShowEditFormCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                                <Button Grid.Column="5"
                                        Content="{Binding IsActive, Converter={StaticResource BoolToInverseConverter}}"
                                        Width="60" Height="28" FontSize="12" Cursor="Hand"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding DataContext.ToggleActiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ===== Create/Edit Form ===== -->
            <Border Margin="0,12,0,0" Padding="20,16" CornerRadius="8"
                    Background="{StaticResource Gray50Brush}"
                    Visibility="{Binding ShowForm, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <StackPanel>
                    <TextBlock FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource Gray900Brush}"
                               Text="新建人员">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Text" Value="编辑人员" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="编码" FontSize="13"
                                   Foreground="{StaticResource Gray700Brush}"
                                   VerticalAlignment="Center" Margin="0,0,8,8" />
                        <TextBox Grid.Row="0" Grid.Column="1" Height="36" Padding="8,0" Margin="0,0,16,8"
                                 Text="{Binding FormCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsEditing, Converter={StaticResource BoolToInverseConverter}}"
                                 Style="{StaticResource FormTextBoxStyle}" />

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="姓名" FontSize="13"
                                   Foreground="{StaticResource Gray700Brush}"
                                   VerticalAlignment="Center" Margin="0,0,8,8" />
                        <TextBox Grid.Row="0" Grid.Column="3" Height="36" Padding="8,0" Margin="0,0,0,8"
                                 Text="{Binding FormName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="性别" FontSize="13"
                                   Foreground="{StaticResource Gray700Brush}"
                                   VerticalAlignment="Center" Margin="0,0,8,8" />
                        <TextBox Grid.Row="1" Grid.Column="1" Height="36" Padding="8,0" Margin="0,0,16,8"
                                 Text="{Binding FormGender, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" />

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="电话" FontSize="13"
                                   Foreground="{StaticResource Gray700Brush}"
                                   VerticalAlignment="Center" Margin="0,0,8,8" />
                        <TextBox Grid.Row="1" Grid.Column="3" Height="36" Padding="8,0" Margin="0,0,0,8"
                                 Text="{Binding FormPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="院区" FontSize="13"
                                   Foreground="{StaticResource Gray700Brush}"
                                   VerticalAlignment="Center" Margin="0,0,8,8" />
                        <ComboBox Grid.Row="2" Grid.Column="1" Height="36" MinWidth="140" Margin="0,0,16,8"
                                  ItemsSource="{Binding Campuses}"
                                  SelectedValue="{Binding FormCampusId, Mode=TwoWay}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="资质类型" FontSize="13"
                                   Foreground="{StaticResource Gray700Brush}"
                                   VerticalAlignment="Center" Margin="0,0,8,8" />
                        <TextBox Grid.Row="2" Grid.Column="1" Height="36" Padding="8,0" Margin="0,0,16,8"
                                 Text="{Binding FormLicenseType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" />

                        <TextBlock Grid.Row="3" Grid.Column="2" Text="资质编号" FontSize="13"
                                   Foreground="{StaticResource Gray700Brush}"
                                   VerticalAlignment="Center" Margin="0,0,8,8" />
                        <TextBox Grid.Row="3" Grid.Column="3" Height="36" Padding="8,0" Margin="0,0,0,8"
                                 Text="{Binding FormLicenseNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" />

                        <TextBlock Grid.Row="4" Grid.Column="2" Text="资质到期" FontSize="13"
                                   Foreground="{StaticResource Gray700Brush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <DatePicker Grid.Row="4" Grid.Column="3" Height="36"
                                    SelectedDate="{Binding FormLicenseExpiry, Mode=TwoWay}" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Content="保存" Width="100" Height="34" Margin="0,0,10,0"
                                FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}" />
                        <Button Content="取消" Width="80" Height="34"
                                FontSize="13" Cursor="Hand"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CancelFormCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
