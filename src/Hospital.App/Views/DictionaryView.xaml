<UserControl x:Class="Hospital.App.Views.DictionaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             FontFamily="Microsoft YaHei, SimHei, sans-serif">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- ===== Header ===== -->
            <Border Padding="32,28" CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#14B8A6" Offset="0.0" />
                        <GradientStop Color="#0D9488" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}"
                               Text="字典管理" />
                    <TextBlock Margin="0,8,0,0" FontSize="14"
                               Foreground="{StaticResource BlueAccentBrush}"
                               Text="维护 ICD 诊断编码、收费项目、药品目录等系统字典" />
                </StackPanel>
            </Border>

            <!-- ===== Error Banner ===== -->
            <Border Margin="0,16,0,0"
                    Style="{StaticResource ErrorBannerStyle}"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="13" Foreground="{StaticResource Red700Brush}"
                           TextWrapping="Wrap" />
            </Border>

            <!-- ===== Main Content: Types (Left) + Items (Right) ===== -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ===== Left: Dictionary Types ===== -->
                <Border Grid.Column="0" Padding="0" CornerRadius="10" Margin="0,0,16,0"
                        Background="{StaticResource WhiteBrush}">
                    <StackPanel>
                        <Grid Margin="16,14,16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource Gray900Brush}"
                                       Text="字典类型" />
                            <Button Grid.Column="1" Content="+" Width="28" Height="28"
                                    FontSize="16" FontWeight="Bold" Cursor="Hand"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ShowCreateTypeFormCommand}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Types}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,8" Margin="8,0,8,2" CornerRadius="6"
                                            Background="{StaticResource Gray50Brush}"
                                            Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding Gesture="LeftClick"
                                                          Command="{Binding DataContext.SelectTypeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource Gray900Brush}"
                                                           Text="{Binding Name}" />
                                                <TextBlock Margin="0,2,0,0" FontSize="11"
                                                           Foreground="{StaticResource Gray500Brush}"
                                                           Text="{Binding Code}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Green600Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0">
                                                <TextBlock.Visibility>
                                                    <Binding Path="IsActive" Converter="{StaticResource BoolToVisibilityConverter}" />
                                                </TextBlock.Visibility>
                                                启用
                                            </TextBlock>
                                            <Button Grid.Column="2" Content="编辑" Width="50" Height="24" Margin="0,0,4,0"
                                                    FontSize="11" Cursor="Hand"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding DataContext.ShowEditTypeFormCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Grid.Column="3"
                                                    Content="{Binding IsActive, Converter={StaticResource BoolToInverseConverter}}"
                                                    Width="50" Height="24" FontSize="11" Cursor="Hand"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding DataContext.ToggleTypeActiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Type Form -->
                        <Border Padding="12,10" Margin="8,4,8,8" CornerRadius="6"
                                Background="{StaticResource BlueSubtleBrush}"
                                Visibility="{Binding ShowTypeForm, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                            <StackPanel>
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource BluePrimaryBrush}" Text="新建/编辑类型" />
                                <TextBox Margin="0,6,0,0" Height="30" Padding="6,0" FontSize="12"
                                         Text="{Binding TypeFormCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsEditingType, Converter={StaticResource BoolToInverseConverter}}"
                                         Style="{StaticResource FormTextBoxStyle}" />
                                <TextBox Margin="0,4,0,0" Height="30" Padding="6,0" FontSize="12"
                                         Text="{Binding TypeFormName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}" />
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="保存" Height="26" Padding="10,0" Margin="0,0,6,0"
                                            FontSize="12" Cursor="Hand"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding SaveTypeCommand}" />
                                    <Button Content="取消" Height="26" Padding="10,0"
                                            FontSize="12" Cursor="Hand"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding CancelTypeFormCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ===== Right: Dictionary Items ===== -->
                <Border Grid.Column="1" Padding="0" CornerRadius="10"
                        Background="{StaticResource WhiteBrush}">
                    <StackPanel>
                        <Grid Margin="16,14,16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource Gray900Brush}">
                                <TextBlock.Text>
                                    <Binding Path="SelectedType.Name" FallbackValue="请选择字典类型" />
                                </TextBlock.Text>
                            </TextBlock>
                            <Button Grid.Column="1" Content="+ 新建项" Height="28" Padding="12,0"
                                    FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ShowCreateItemFormCommand}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Items}" Margin="8,0,8,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,6" Margin="0,0,0,2" CornerRadius="4"
                                            Background="{StaticResource Gray50Brush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Gray700Brush}"
                                                       Text="{Binding Code}" Margin="0,0,12,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" FontSize="13"
                                                       Foreground="{StaticResource Gray900Brush}"
                                                       Text="{Binding Name}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Green600Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock.Visibility>
                                                    <Binding Path="IsActive" Converter="{StaticResource BoolToVisibilityConverter}" />
                                                </TextBlock.Visibility>
                                                启用
                                            </TextBlock>
                                            <Button Grid.Column="3" Content="编辑" Width="50" Height="24"
                                                    FontSize="11" Cursor="Hand"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding DataContext.ShowEditItemFormCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Item Form -->
                        <Border Padding="12,10" Margin="8,4,8,8" CornerRadius="6"
                                Background="{StaticResource BlueSubtleBrush}"
                                Visibility="{Binding ShowItemForm, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                            <StackPanel>
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource BluePrimaryBrush}" Text="新建/编辑字典项" />
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="编码" FontSize="11"
                                               Foreground="{StaticResource Gray700Brush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBox Grid.Column="1" Height="28" Padding="4,0" Margin="0,0,8,0" FontSize="11"
                                             Text="{Binding ItemFormCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsEditingItem, Converter={StaticResource BoolToInverseConverter}}"
                                             Style="{StaticResource FormTextBoxStyle}" />
                                    <TextBlock Grid.Column="2" Text="名称" FontSize="11"
                                               Foreground="{StaticResource Gray700Brush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBox Grid.Column="3" Height="28" Padding="4,0" FontSize="11"
                                             Text="{Binding ItemFormName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="保存" Height="26" Padding="10,0" Margin="0,0,6,0"
                                            FontSize="12" Cursor="Hand"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding SaveItemCommand}" />
                                    <Button Content="取消" Height="26" Padding="10,0"
                                            FontSize="12" Cursor="Hand"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding CancelItemFormCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
