<UserControl x:Class="Hospital.App.Views.PatientRegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">
            <!-- Header -->
            <Border Padding="32,28" CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#14B8A6" Offset="0.0" />
                        <GradientStop Color="#0D9488" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}"
                               Text="患者建档" />
                    <TextBlock Margin="0,8,0,0" FontSize="14"
                               Foreground="{StaticResource BlueAccentBrush}"
                               Text="为患者建立档案，支持身份证号、手机号等多方式录入，自动查重" />
                </StackPanel>
            </Border>

            <!-- Error/Success banner -->
            <Border Style="{StaticResource ErrorBannerStyle}"
                    Margin="0,16,0,0"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource Red700Brush}"
                           FontSize="13" />
            </Border>

            <!-- Duplicate warning -->
            <Border Background="{StaticResource Amber600Brush}"
                    CornerRadius="6" Padding="10,8"
                    Margin="0,16,0,0"
                    Visibility="{Binding ShowDuplicateWarning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding DuplicateMessage}"
                           Foreground="{StaticResource WhiteBrush}"
                           FontSize="13" />
            </Border>

            <!-- Registration form -->
            <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource Gray900Brush}"
                               Text="基本信息" />

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Row 0: 病历号 -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Style="{StaticResource FormLabelStyle}"
                                   VerticalAlignment="Center"
                                   Text="病历号 *" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 Text="{Binding PatientNo, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,16,16" />

                        <!-- Row 1: 姓名 -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Style="{StaticResource FormLabelStyle}"
                                   VerticalAlignment="Center"
                                   Text="姓名 *" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,16,16" />

                        <!-- Row 2: 性别 -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Style="{StaticResource FormLabelStyle}"
                                   VerticalAlignment="Center"
                                   Text="性别" />
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  Height="38" MinWidth="300"
                                  ItemsSource="{Binding GenderOptions}"
                                  SelectedItem="{Binding SelectedGender}"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,16,16">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="14" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Row 3: 出生日期 -->
                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Style="{StaticResource FormLabelStyle}"
                                   VerticalAlignment="Center"
                                   Text="出生日期" />
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 Text="{Binding BirthDate, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,16,16" />
                    </Grid>

                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource Gray900Brush}"
                               Text="联系方式与证件" />

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Row 0: 手机号 -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Style="{StaticResource FormLabelStyle}"
                                   VerticalAlignment="Center"
                                   Text="手机号" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,16,16" />

                        <!-- Row 1: 身份证号 -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Style="{StaticResource FormLabelStyle}"
                                   VerticalAlignment="Center"
                                   Text="身份证号" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 Text="{Binding IdCard, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,16,16" />
                    </Grid>

                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource Gray900Brush}"
                               Text="其他信息" />

                    <TextBlock Margin="0,16,0,6"
                               Style="{StaticResource FormLabelStyle}"
                               Text="过敏史" />
                    <TextBox Text="{Binding AllergiesText, UpdateSourceTrigger=PropertyChanged}"
                             Height="60" FontSize="14"
                             Padding="12,8"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             BorderBrush="{StaticResource Gray300Brush}"
                             BorderThickness="1"
                             Foreground="{StaticResource Gray900Brush}"
                             VerticalContentAlignment="Top" />

                    <!-- Submit -->
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,24,0,0"
                            HorizontalAlignment="Left"
                            Width="160"
                            Command="{Binding SubmitCommand}"
                            Content="提交" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
