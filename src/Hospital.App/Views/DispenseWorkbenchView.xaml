<UserControl x:Class="Hospital.App.Views.DispenseWorkbenchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             FontFamily="Microsoft YaHei, SimHei, sans-serif">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- ===== Header ===== -->
            <Border Padding="32,28" CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#10B981" Offset="0.0" />
                        <GradientStop Color="#059669" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}"
                               Text="发药工作台" />
                    <TextBlock Margin="0,8,0,0" FontSize="14"
                               Foreground="{StaticResource BlueAccentBrush}"
                               Text="门诊处方审核、发药、退药，管控药双人核对" />
                </StackPanel>
            </Border>

            <!-- ===== Error Banner ===== -->
            <Border Margin="0,16,0,0"
                    Style="{StaticResource ErrorBannerStyle}"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="13" Foreground="{StaticResource Red700Brush}"
                           TextWrapping="Wrap" />
            </Border>

            <!-- ===== Success Banner ===== -->
            <Border Margin="0,8,0,0" Padding="10,8" CornerRadius="6"
                    Background="{StaticResource Green50Brush}"
                    BorderBrush="{StaticResource Green200Brush}" BorderThickness="1"
                    Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="操作成功！" FontSize="13"
                           Foreground="{StaticResource Green800Brush}" FontWeight="SemiBold" />
            </Border>

            <!-- ===== Step 1: Patient Search ===== -->
            <Border Margin="0,16,0,0" Padding="24,20" CornerRadius="10"
                    Background="{StaticResource WhiteBrush}">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource Gray900Brush}"
                               Text="① 选择患者" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Height="38" Padding="12,0"
                                 Text="{Binding PatientKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" />
                        <Button Grid.Column="1" Content="搜索" Width="100" Height="40" Margin="12,0,0,0"
                                FontSize="15" FontWeight="SemiBold" Cursor="Hand"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SearchPatientCommand}" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding PatientResults}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" Margin="0,0,0,4" CornerRadius="6"
                                        Background="{StaticResource Gray50Brush}"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                                      Command="{Binding DataContext.SelectPatientCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}" />
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                                Background="{StaticResource BlueSubtleBrush}" Margin="0,0,12,0">
                                            <TextBlock FontSize="18" Foreground="{StaticResource WhiteBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Text="💊" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Gray900Brush}"
                                                       Text="{Binding Name}" />
                                            <TextBlock Margin="0,2,0,0" FontSize="13"
                                                       Foreground="{StaticResource Gray500Brush}"
                                                       Text="{Binding PatientNo, StringFormat='病历号: {0}'}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Margin="0,8,0,0" Padding="12,10" CornerRadius="6"
                            Background="{StaticResource BlueSubtleBrush}"
                            Visibility="{Binding SelectedPatientInfo, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource BluePrimaryBrush}"
                                   Text="{Binding SelectedPatientInfo}" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== Step 2: Paid Prescriptions ===== -->
            <Border Margin="0,16,0,0" Padding="24,20" CornerRadius="10"
                    Background="{StaticResource WhiteBrush}">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource Gray900Brush}"
                               Text="② 已缴费处方" />

                    <TextBlock Margin="0,8,0,0" FontSize="13"
                               Foreground="{StaticResource Gray500Brush}"
                               Text="{Binding PaidPrescriptions.Count, StringFormat='共 {0} 张处方'}" />

                    <ItemsControl ItemsSource="{Binding PaidPrescriptions}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,10" Margin="0,0,0,6" CornerRadius="6"
                                        Background="{StaticResource Gray50Brush}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BluePrimaryBrush}"
                                                       Text="{Binding Status}" Margin="0,0,12,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" FontSize="12"
                                                       Foreground="{StaticResource Gray400Brush}"
                                                       Text="{Binding Id, StringFormat='处方 #{0}'}"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="2" Content="发药" Width="60" Height="30" Margin="0,0,8,0"
                                                    FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Command="{Binding DataContext.DispenseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}" />
                                            <Button Grid.Column="3" Content="退药" Width="60" Height="30"
                                                    FontSize="12" Cursor="Hand"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding DataContext.ReturnCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}" />
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Items}" Margin="0,6,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8,6" Margin="0,0,0,2" CornerRadius="4"
                                                            Background="{StaticResource WhiteBrush}">
                                                        <TextBlock FontSize="13"
                                                                   Foreground="{StaticResource Gray700Brush}">
                                                            <Run Text="{Binding DrugName}" FontWeight="SemiBold" />
                                                            <Run Text="{Binding Spec}" />
                                                            <Run Text=" | " />
                                                            <Run Text="{Binding Dosage}" />
                                                            <Run Text="{Binding Freq}" />
                                                            <Run Text=" | " />
                                                            <Run Text="{Binding Qty, StringFormat='{}{0} 剂'}" />
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
