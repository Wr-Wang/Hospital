<UserControl x:Class="Hospital.App.Views.UserRoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             FontFamily="Microsoft YaHei, SimHei, sans-serif">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- ===== Header ===== -->
            <Border Padding="32,28" CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6366F1" Offset="0.0" />
                        <GradientStop Color="#4F46E5" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}"
                               Text="用户与角色" />
                    <TextBlock Margin="0,8,0,0" FontSize="14"
                               Foreground="#C7D2FE"
                               Text="管理用户账号、角色权限配置" />
                </StackPanel>
            </Border>

            <!-- ===== Error Banner ===== -->
            <Border Margin="0,16,0,0"
                    Style="{StaticResource ErrorBannerStyle}"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="13" Foreground="{StaticResource Red700Brush}"
                           TextWrapping="Wrap" />
            </Border>

            <!-- ===== TabControl ===== -->
            <Border Margin="0,16,0,0" Padding="0" CornerRadius="10"
                    Background="{StaticResource WhiteBrush}">
                <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                            Padding="0" Margin="0"
                            Background="Transparent"
                            BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabPanel">
                            <Setter Property="Background" Value="{StaticResource Gray50Brush}" />
                        </Style>
                    </TabControl.Resources>

                    <!-- ===== Tab 1: Users ===== -->
                    <TabItem Header="用户管理">
                        <TabItem.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="用户管理" FontSize="14" FontWeight="SemiBold" Padding="16,10" />
                            </DataTemplate>
                        </TabItem.HeaderTemplate>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource Gray900Brush}"
                                               Text="{Binding Users.Count, StringFormat='系统用户（{0} 人）'}" />
                                    <Button Grid.Column="1" Content="+ 新建用户" Height="34" Padding="16,0"
                                            FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding ToggleCreateUserCommand}" />
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Users}" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14,10" Margin="0,0,0,4" CornerRadius="6"
                                                    Background="{StaticResource Gray50Brush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                                            Background="{StaticResource BlueLightBrush}" Margin="0,0,12,0">
                                                        <TextBlock FontSize="16" Foreground="{StaticResource WhiteBrush}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Text="👤" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Gray900Brush}"
                                                                   Text="{Binding DisplayName}" />
                                                        <TextBlock Margin="0,2,0,0" FontSize="12"
                                                                   Foreground="{StaticResource Gray500Brush}">
                                                            <Run Text="{Binding LoginName}" />
                                                            <Run Text=" | " />
                                                            <Run Text="{Binding CampusName}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <WrapPanel Grid.Column="2" Margin="12,0" VerticalAlignment="Center">
                                                        <ItemsControl ItemsSource="{Binding Roles}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Padding="8,3" Margin="2,0" CornerRadius="4"
                                                                            Background="{StaticResource BlueSubtleBrush}">
                                                                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource BluePrimaryBrush}"
                                                                                   Text="{Binding}" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </WrapPanel>
                                                    <TextBlock Grid.Column="3" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{StaticResource Green600Brush}"
                                                               VerticalAlignment="Center" Margin="0,0,12,0">
                                                        <TextBlock.Visibility>
                                                            <Binding Path="IsActive" Converter="{StaticResource BoolToVisibilityConverter}" />
                                                        </TextBlock.Visibility>
                                                        正常
                                                    </TextBlock>
                                                    <Button Grid.Column="4"
                                                            Content="{Binding IsActive, Converter={StaticResource BoolToInverseConverter}, StringFormat={}{0}}"
                                                            Width="60" Height="28" FontSize="12" Cursor="Hand"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding DataContext.ToggleUserActiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Create User Form -->
                                <Border Margin="0,16,0,0" Padding="16,14" CornerRadius="8"
                                        Background="{StaticResource Gray50Brush}"
                                        Visibility="{Binding ShowCreateUser, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                                    <StackPanel>
                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Gray900Brush}" Text="新建用户" />
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="登录名" FontSize="13"
                                                       Foreground="{StaticResource Gray700Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,8" />
                                            <TextBox Grid.Row="0" Grid.Column="1" Height="36" Padding="8,0" Margin="0,0,16,8"
                                                     Text="{Binding NewLoginName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FormTextBoxStyle}" />
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="密码" FontSize="13"
                                                       Foreground="{StaticResource Gray700Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,8" />
                                            <TextBox Grid.Row="0" Grid.Column="3" Height="36" Padding="8,0" Margin="0,0,0,8"
                                                     Text="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FormTextBoxStyle}" />

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="显示名称" FontSize="13"
                                                       Foreground="{StaticResource Gray700Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,8" />
                                            <TextBox Grid.Row="1" Grid.Column="1" Height="36" Padding="8,0" Margin="0,0,16,8"
                                                     Text="{Binding NewDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FormTextBoxStyle}" />
                                            <TextBlock Grid.Row="1" Grid.Column="2" Text="院区" FontSize="13"
                                                       Foreground="{StaticResource Gray700Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,8" />
                                            <TextBox Grid.Row="1" Grid.Column="3" Height="36" Padding="8,0" Margin="0,0,0,8"
                                                     Text="{Binding NewCampusName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FormTextBoxStyle}" />

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="角色" FontSize="13"
                                                       Foreground="{StaticResource Gray700Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Height="36" Padding="8,0"
                                                     Text="{Binding NewUserRole, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FormTextBoxStyle}" />
                                        </Grid>
                                        <Button Content="创建用户" Width="120" Height="34" Margin="0,12,0,0"
                                                FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                HorizontalAlignment="Left"
                                                Command="{Binding CreateUserCommand}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Tab 2: Roles ===== -->
                    <TabItem Header="角色权限">
                        <TabItem.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="角色权限" FontSize="14" FontWeight="SemiBold" Padding="16,10" />
                            </DataTemplate>
                        </TabItem.HeaderTemplate>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource Gray900Brush}"
                                               Text="角色列表" />
                                    <Button Grid.Column="1" Content="+ 新建角色" Height="34" Padding="16,0"
                                            FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding ToggleCreateRoleCommand}" />
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Roles}" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14,10" Margin="0,0,0,4" CornerRadius="6"
                                                    Background="{StaticResource Gray50Brush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Padding="10,5" CornerRadius="4"
                                                            Background="{StaticResource BlueLightBrush}" Margin="0,0,12,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource WhiteBrush}"
                                                                   Text="{Binding Name}" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock FontSize="13"
                                                                   Foreground="{StaticResource Gray500Brush}"
                                                                   Text="{Binding Description}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="2" Content="删除" Width="60" Height="28"
                                                            FontSize="12" Cursor="Hand"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding DataContext.DeleteRoleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Create Role Form -->
                                <Border Margin="0,16,0,0" Padding="16,14" CornerRadius="8"
                                        Background="{StaticResource Gray50Brush}"
                                        Visibility="{Binding ShowCreateRole, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                                    <StackPanel>
                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Gray900Brush}" Text="新建角色" />
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="角色名称" FontSize="13"
                                                       Foreground="{StaticResource Gray700Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBox Grid.Column="1" Height="36" Padding="8,0" Margin="0,0,16,0"
                                                     Text="{Binding NewRoleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FormTextBoxStyle}" />
                                            <TextBlock Grid.Column="2" Text="描述" FontSize="13"
                                                       Foreground="{StaticResource Gray700Brush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBox Grid.Column="3" Height="36" Padding="8,0"
                                                     Text="{Binding NewRoleDesc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FormTextBoxStyle}" />
                                        </Grid>

                                        <TextBlock Margin="0,16,0,0" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Gray900Brush}" Text="权限配置" />

                                        <ItemsControl ItemsSource="{Binding AllPermissions}" Margin="0,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,8">
                                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Gray700Brush}"
                                                                   Text="{Binding GroupName}" />
                                                        <WrapPanel Margin="0,6,0,0">
                                                            <ItemsControl ItemsSource="{Binding Permissions}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Padding="8,6" Margin="4,4" CornerRadius="6"
                                                                                Background="{StaticResource WhiteBrush}"
                                                                                BorderBrush="{StaticResource Gray200Brush}"
                                                                                BorderThickness="1"
                                                                                Cursor="Hand">
                                                                            <Border.InputBindings>
                                                                                <MouseBinding Gesture="LeftClick"
                                                                                              Command="{Binding DataContext.ToggleRolePermissionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                              CommandParameter="{Binding Value}" />
                                                                            </Border.InputBindings>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Border Width="16" Height="16" CornerRadius="3"
                                                                                        BorderBrush="{StaticResource Gray300Brush}" BorderThickness="1"
                                                                                        Background="{StaticResource WhiteBrush}" Margin="0,0,8,0">
                                                                                    <TextBlock Text="✓" FontSize="10"
                                                                                               Foreground="{StaticResource WhiteBrush}"
                                                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                                </Border>
                                                                                <TextBlock FontSize="12"
                                                                                           Foreground="{StaticResource Gray700Brush}"
                                                                                           Text="{Binding Label}" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Button Content="创建角色" Width="120" Height="34" Margin="0,12,0,0"
                                                FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                HorizontalAlignment="Left"
                                                Command="{Binding CreateRoleCommand}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
