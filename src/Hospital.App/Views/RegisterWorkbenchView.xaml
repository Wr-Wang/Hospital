<UserControl x:Class="Hospital.App.Views.RegisterWorkbenchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Hospital.App.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             FontFamily="Microsoft YaHei, SimHei, sans-serif">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- ===== Header ===== -->
            <Border Padding="32,28" CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#14B8A6" Offset="0.0" />
                        <GradientStop Color="#0D9488" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}"
                               Text="挂号工作台" />
                    <TextBlock Margin="0,8,0,0" FontSize="14"
                               Foreground="{StaticResource BlueAccentBrush}"
                               Text="窗口快速挂号与退号" />
                </StackPanel>
            </Border>

            <!-- ===== Error / Success Banners ===== -->
            <Border Margin="0,16,0,0" Padding="10,8" CornerRadius="6"
                    Background="{StaticResource Red50Brush}"
                    BorderBrush="{StaticResource Red200Brush}"
                    BorderThickness="1"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="13" Foreground="{StaticResource Red700Brush}"
                           TextWrapping="Wrap" />
            </Border>

            <Border Margin="0,12,0,0" Padding="10,8" CornerRadius="6"
                    Background="{StaticResource Green50Brush}"
                    BorderBrush="#A7F3D0" BorderThickness="1"
                    Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="挂号成功！" FontSize="13"
                           Foreground="{StaticResource Green800Brush}" FontWeight="SemiBold" />
            </Border>

            <!-- ===== Step 1: Department + Doctor ===== -->
            <Border Margin="0,16,0,0" Padding="24,20" CornerRadius="10"
                    Background="{StaticResource WhiteBrush}"
                    Effect="{StaticResource CardShadowEffect}">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource Gray900Brush}"
                               Text="① 选择科室与医生" />
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="科室" FontSize="13" FontWeight="Medium"
                                   Style="{StaticResource FormLabelStyle}" />
                        <ComboBox Grid.Column="1" Height="38" MinWidth="220" Margin="0,0,16,0"
                                  ItemsSource="{Binding Departments}"
                                  SelectedItem="{Binding SelectedDept, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  HorizontalAlignment="Left" />
                        <TextBlock Grid.Column="2" Text="医生" FontSize="13" FontWeight="Medium"
                                   Style="{StaticResource FormLabelStyle}" />
                        <ComboBox Grid.Column="3" Height="38" MinWidth="220"
                                  ItemsSource="{Binding Doctors}"
                                  SelectedItem="{Binding SelectedDoctor, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  HorizontalAlignment="Left" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Step 2: Available Schedules ===== -->
            <Border Margin="0,16,0,0" Padding="24,20" CornerRadius="10"
                    Background="{StaticResource WhiteBrush}"
                    Effect="{StaticResource CardShadowEffect}">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource Gray900Brush}"
                               Text="② 选择排班时段" />

                    <TextBlock Margin="0,12,0,0" FontSize="13"
                               Foreground="{StaticResource Gray500Brush}"
                               Text="{Binding AvailableSchedules.Count, StringFormat='可用排班: {0} 条'}" />

                    <ItemsControl ItemsSource="{Binding AvailableSchedules}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="16,12" CornerRadius="8"
                                        Background="{StaticResource Gray50Brush}"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                                      Command="{Binding DataContext.SelectSlotCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}" />
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Gray900Brush}"
                                                       Text="{Binding ScheduleDate}" />
                                        </StackPanel>
                                        <WrapPanel Grid.Column="1" Margin="16,0,0,0">
                                            <ItemsControl ItemsSource="{Binding Slots}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="4,4" Padding="10,6" CornerRadius="6"
                                                                Background="{StaticResource WhiteBrush}"
                                                                BorderBrush="{StaticResource Gray200Brush}"
                                                                BorderThickness="1">
                                                            <StackPanel>
                                                                <TextBlock FontSize="13" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource Gray700Brush}"
                                                                           Text="{Binding SlotName}" />
                                                                <TextBlock Margin="0,2,0,0" FontSize="12"
                                                                           Foreground="{StaticResource Green600Brush}"
                                                                           Text="{Binding AvailableQuota, StringFormat='余 {0} 号'}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </WrapPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ===== Step 3: Patient Search ===== -->
            <Border Margin="0,16,0,0" Padding="24,20" CornerRadius="10"
                    Background="{StaticResource WhiteBrush}"
                    Effect="{StaticResource CardShadowEffect}">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource Gray900Brush}"
                               Text="③ 选择患者" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Height="38" Padding="12,0"
                                 Text="{Binding PatientKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" />
                        <Button Grid.Column="1" Content="搜索" Width="100" Height="40" Margin="12,0,0,0"
                                FontSize="15" FontWeight="SemiBold" Cursor="Hand"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SearchPatientCommand}" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding PatientResults}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" Margin="0,0,0,4" CornerRadius="6"
                                        Background="{StaticResource Gray50Brush}"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                                      Command="{Binding DataContext.SelectPatientCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}" />
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                                Background="{StaticResource BlueLightBrush}" Margin="0,0,12,0">
                                            <TextBlock FontSize="18" Foreground="{StaticResource WhiteBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Text="👤" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Gray900Brush}"
                                                       Text="{Binding Name}" />
                                            <TextBlock Margin="0,2,0,0" FontSize="13"
                                                       Foreground="{StaticResource Gray500Brush}">
                                                <Run Text="{Binding Gender}" />
                                                <Run Text=" | " />
                                                <Run Text="{Binding IdCard}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" FontSize="13"
                                                   Foreground="{StaticResource Gray400Brush}"
                                                   Text="{Binding PatientNo}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Selected patient display -->
                    <Border Margin="0,8,0,0" Padding="12,10" CornerRadius="6"
                            Background="{StaticResource BlueSubtleBrush}"
                            Visibility="{Binding SelectedPatientInfo, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource BluePrimaryBrush}"
                                   Text="{Binding SelectedPatientInfo}" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== Step 4: Confirm ===== -->
            <Border Margin="0,16,0,0" Padding="24,20" CornerRadius="10"
                    Background="{StaticResource WhiteBrush}"
                    Effect="{StaticResource CardShadowEffect}">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource Gray900Brush}"
                               Text="④ 确认挂号" />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="科室"
                                   FontSize="13" Foreground="{StaticResource Gray700Brush}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Margin="8,0,16,12"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Gray900Brush}"
                                   Text="{Binding SelectedDept.Name, FallbackValue='--'}" />

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="医生"
                                   FontSize="13" Foreground="{StaticResource Gray700Brush}" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Margin="8,0,0,12"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Gray900Brush}"
                                   Text="{Binding SelectedDoctor.Name, FallbackValue='--'}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="就诊时段"
                                   FontSize="13" Foreground="{StaticResource Gray700Brush}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="8,0,16,12"
                                   FontSize="14" Foreground="{StaticResource Gray900Brush}"
                                   Text="{Binding SelectedSlotName, FallbackValue='--'}" />

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="患者"
                                   FontSize="13" Foreground="{StaticResource Gray700Brush}" />
                        <TextBlock Grid.Row="1" Grid.Column="3" Margin="8,0,0,12"
                                   FontSize="14" Foreground="{StaticResource Gray900Brush}"
                                   Text="{Binding SelectedPatientInfo, FallbackValue='请先选择患者'}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="日期"
                                   FontSize="13" Foreground="{StaticResource Gray700Brush}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="8,0,0,0"
                                   FontSize="14" Foreground="{StaticResource Gray900Brush}"
                                   Text="{Binding TodayDate}" />
                    </Grid>

                    <Button Content="确认挂号" Width="200" Height="44" Margin="0,12,0,0"
                            FontSize="16" FontWeight="Bold" Cursor="Hand"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Left"
                            Command="{Binding RegisterCommand}" />
                </StackPanel>
            </Border>

            <!-- ===== Today's Registrations ===== -->
            <Border Margin="0,16,0,0" Padding="24,20" CornerRadius="10"
                    Background="{StaticResource WhiteBrush}"
                    Effect="{StaticResource CardShadowEffect}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource Gray900Brush}"
                                   Text="{Binding TodayRegistrations.Count, StringFormat='今日挂号（{0} 条）'}" />
                        <Button Grid.Column="1" Content="刷新" Height="32" Padding="12,0"
                                FontSize="13" Cursor="Hand"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RefreshCommand}" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding TodayRegistrations}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" Margin="0,0,0,4" CornerRadius="6"
                                        Background="{StaticResource Gray50Brush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource BluePrimaryBrush}"
                                                   Text="{Binding QueueNumber, StringFormat='#{0}'}"
                                                   VerticalAlignment="Center" Margin="0,0,16,0" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Gray900Brush}"
                                                       Text="{Binding PatientDisplay}" />
                                            <TextBlock Margin="0,2,0,0" FontSize="12"
                                                       Foreground="{StaticResource Gray500Brush}">
                                                <Run Text="{Binding SlotName}" />
                                                <Run Text=" | " />
                                                <Run Text="{Binding RegisterTime}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Grid.Column="3" Padding="8,4" CornerRadius="4"
                                                Background="{StaticResource BlueSubtleBrush}"
                                                VerticalAlignment="Center" Margin="12,0">
                                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BluePrimaryBrush}"
                                                       Text="{Binding Status}" />
                                        </Border>
                                        <Button Grid.Column="4" Content="退号" Width="60" Height="30"
                                                FontSize="12" Cursor="Hand"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.VoidRegistrationCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Id}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
