<UserControl x:Class="Hospital.App.Views.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Hospital.App.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             FontFamily="Microsoft YaHei, SimHei, sans-serif">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- ===== Header ===== -->
            <Border Padding="32,28" CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#14B8A6" Offset="0.0" />
                        <GradientStop Color="#0D9488" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}"
                               Text="排班号表" />
                    <TextBlock Margin="0,8,0,0" FontSize="14"
                               Foreground="{StaticResource BlueAccentBrush}"
                               Text="管理医生出诊排班与号源配额" />
                </StackPanel>
            </Border>

            <!-- ===== Error Banner ===== -->
            <Border Margin="0,16,0,0"
                    Style="{StaticResource ErrorBannerStyle}"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="13"
                           Foreground="{StaticResource Red700Brush}"
                           TextWrapping="Wrap" />
            </Border>

            <!-- ===== Filter Section ===== -->
            <Border Margin="0,16,0,0" Padding="24,20" CornerRadius="10"
                    Background="{StaticResource WhiteBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Dept combo -->
                    <TextBlock Grid.Column="0" Text="科室" FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource Gray700Brush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Grid.Column="1" Height="38" MinWidth="180" Margin="0,0,16,0"
                              ItemsSource="{Binding Departments}"
                              SelectedItem="{Binding SelectedDept, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              HorizontalAlignment="Left" />

                    <!-- Doctor combo -->
                    <TextBlock Grid.Column="2" Text="医生" FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource Gray700Brush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Grid.Column="3" Height="38" MinWidth="180" Margin="0,0,16,0"
                              ItemsSource="{Binding Doctors}"
                              SelectedItem="{Binding SelectedDoctor, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              HorizontalAlignment="Left" />

                    <!-- Date -->
                    <TextBlock Grid.Column="4" Text="日期" FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource Gray700Brush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Grid.Column="5" Height="38" MinWidth="140"
                             Text="{Binding ScheduleDate, Mode=TwoWay}"
                             Style="{StaticResource FormTextBoxStyle}"
                             HorizontalAlignment="Left" />
                </Grid>
                <Border.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding LoadSchedulesCommand}" />
                </Border.InputBindings>
            </Border>

            <!-- ===== Action Bar ===== -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="查 询" Width="100" Height="40"
                        FontSize="15" FontWeight="SemiBold"
                        Cursor="Hand"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding LoadSchedulesCommand}" />
                <Button Grid.Column="2" Content="＋ 新建排班" Height="40" Padding="20,0"
                        FontSize="15" FontWeight="SemiBold"
                        Cursor="Hand"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ToggleCreateFormCommand}" />
            </Grid>

            <!-- ===== Create Form (collapsible) ===== -->
            <Border Margin="0,16,0,0" Padding="24,20" CornerRadius="10"
                    Background="{StaticResource WhiteBrush}"
                    Visibility="{Binding ShowCreateForm, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Gray900Brush}"
                               Text="新建排班" />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Text="科室 *" FontSize="13" FontWeight="Medium"
                                   Style="{StaticResource FormLabelStyle}" />
                        <ComboBox Grid.Column="1" Height="38" MinWidth="200" Margin="0,0,16,16"
                                  ItemsSource="{Binding Departments}"
                                  SelectedItem="{Binding CreateDept, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  HorizontalAlignment="Left" />

                        <TextBlock Grid.Column="2" Text="医生 *" FontSize="13" FontWeight="Medium"
                                   Style="{StaticResource FormLabelStyle}" />
                        <ComboBox Grid.Column="3" Height="38" MinWidth="200" Margin="0,0,0,16"
                                  ItemsSource="{Binding Doctors}"
                                  SelectedItem="{Binding CreateDoctor, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  HorizontalAlignment="Left" />
                    </Grid>

                    <TextBlock Grid.Column="0" Text="排班日期 *" FontSize="13" FontWeight="Medium"
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBox Height="38" MinWidth="200" MaxWidth="200" Margin="0,0,0,16"
                             Text="{Binding CreateDate, Mode=TwoWay}"
                             Style="{StaticResource FormTextBoxStyle}"
                             HorizontalAlignment="Left" />

                    <!-- Slots -->
                    <TextBlock Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Gray700Brush}" Text="时段与配额" />
                    <ItemsControl ItemsSource="{Binding CreateSlots}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="时段" FontSize="13"
                                               Foreground="{StaticResource Gray700Brush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBox Grid.Column="1" Width="80" Height="36" Margin="0,0,12,0"
                                             Text="{Binding SlotName, Mode=TwoWay}" Style="{StaticResource FormTextBoxStyle}" />
                                    <TextBlock Grid.Column="2" Text="开始" FontSize="13"
                                               Foreground="{StaticResource Gray700Brush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBox Grid.Column="3" Width="80" Height="36" Margin="0,0,12,0"
                                             Text="{Binding StartTime, Mode=TwoWay}" Style="{StaticResource FormTextBoxStyle}" />
                                    <TextBlock Grid.Column="4" Text="结束" FontSize="13"
                                               Foreground="{StaticResource Gray700Brush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBox Grid.Column="5" Width="80" Height="36" Margin="0,0,12,0"
                                             Text="{Binding EndTime, Mode=TwoWay}" Style="{StaticResource FormTextBoxStyle}" />
                                    <TextBlock Grid.Column="6" Text="配额" FontSize="13"
                                               Foreground="{StaticResource Gray700Brush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBox Grid.Column="7" Width="60" Height="36"
                                             Text="{Binding TotalQuota, Mode=TwoWay}" Style="{StaticResource FormTextBoxStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="＋ 添加时段" Height="36" Padding="16,0"
                                FontSize="14" Cursor="Hand"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AddSlotCommand}" />
                        <Button Content="提交排班" Width="160" Height="40" Margin="12,0,0,0"
                                FontSize="15" FontWeight="SemiBold" Cursor="Hand"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CreateScheduleCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Schedule List ===== -->
            <TextBlock Margin="0,20,0,8" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource Gray900Brush}"
                       Text="{Binding Schedules.Count, StringFormat='排班列表（共 {0} 条）'}" />

            <ItemsControl ItemsSource="{Binding Schedules}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="20,14" CornerRadius="10"
                                Background="{StaticResource WhiteBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Left: doctor + date info -->
                                <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource Gray900Brush}"
                                               Text="{Binding ScheduleDate}" />
                                </StackPanel>

                                <!-- Center: slots -->
                                <WrapPanel Grid.Row="0" Grid.Column="1" Margin="24,0,0,0">
                                    <ItemsControl ItemsSource="{Binding Slots}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="4,4" Padding="12,8" CornerRadius="6"
                                                        Background="{StaticResource Gray50Brush}">
                                                    <StackPanel>
                                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Gray700Brush}"
                                                                   Text="{Binding SlotName}" />
                                                        <TextBlock Margin="0,4,0,0" FontSize="12"
                                                                   Foreground="{StaticResource Gray500Brush}">
                                                            <Run Text="总" /><Run Text="{Binding TotalQuota}" />
                                                            <Run Text=" 已约" /><Run Text="{Binding BookedQuota}" Foreground="{StaticResource Amber600Brush}" />
                                                            <Run Text=" 余" /><Run Text="{Binding AvailableQuota}" Foreground="{StaticResource Green600Brush}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </WrapPanel>

                                <!-- Right: status + actions -->
                                <StackPanel Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <Border Padding="10,4" CornerRadius="4"
                                            Background="{StaticResource BlueSubtleBrush}"
                                            HorizontalAlignment="Center">
                                        <TextBlock FontSize="12" Foreground="{StaticResource BluePrimaryBrush}"
                                                   Text="{Binding Status}" />
                                    </Border>
                                </StackPanel>

                                <!-- Row 2: action buttons -->
                                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                    <Button Content="发布" Width="60" Height="26" Margin="0,0,6,0"
                                            FontSize="11" Cursor="Hand"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding DataContext.PublishScheduleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}" />
                                    <Button Content="停用" Width="60" Height="26"
                                            FontSize="11" Cursor="Hand"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding DataContext.DeactivateScheduleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
