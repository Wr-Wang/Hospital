<UserControl x:Class="Hospital.App.Views.Placeholder.PagePlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">
            <!-- Module header banner -->
            <Border Padding="32,28"
                    CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#14B8A6" Offset="0.0" />
                        <GradientStop Color="#0D9488" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock x:Name="ModuleTitle"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}"
                               Text="模块名称" />
                    <TextBlock x:Name="ModuleDescription"
                               Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{StaticResource BlueAccentBrush}"
                               TextWrapping="Wrap"
                               Text="模块功能描述" />
                </StackPanel>
            </Border>

            <!-- Coming soon card -->
            <Border Style="{StaticResource CardStyle}"
                    Margin="0,24,0,0">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,48,0,48">
                    <TextBlock Text="🛠️"
                               FontSize="40"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,16,0,0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Gray700Brush}"
                               Text="功能开发中"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="13"
                               Foreground="{StaticResource Gray500Brush}"
                               Text="此模块将在后续版本中实现"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
