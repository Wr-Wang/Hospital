<UserControl x:Class="Hospital.App.Views.Placeholder.HomePlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">
            <!-- Welcome banner -->
            <Border Padding="32,28"
                    CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#14B8A6" Offset="0.0" />
                        <GradientStop Color="#0D9488" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}"
                               Text="欢迎使用医院管理系统" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{StaticResource BlueAccentBrush}"
                               TextWrapping="Wrap"
                               Text="本系统提供院区管理、挂号工作台等功能模块，请通过左侧菜单导航使用。" />
                </StackPanel>
            </Border>

            <!-- Quick stats -->
            <Grid Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,8,0"
                        Padding="20,16">
                    <StackPanel>
                        <TextBlock FontSize="13"
                                   Foreground="{StaticResource Gray500Brush}"
                                   Text="今日挂号" />
                        <TextBlock FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BluePrimaryBrush}"
                                   Margin="0,8,0,0"
                                   Text="—" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource CardStyle}"
                        Margin="8,0,8,0"
                        Padding="20,16">
                    <StackPanel>
                        <TextBlock FontSize="13"
                                   Foreground="{StaticResource Gray500Brush}"
                                   Text="院区总数" />
                        <TextBlock FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Green600Brush}"
                                   Margin="0,8,0,0"
                                   Text="—" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource CardStyle}"
                        Margin="8,0,0,0"
                        Padding="20,16">
                    <StackPanel>
                        <TextBlock FontSize="13"
                                   Foreground="{StaticResource Gray500Brush}"
                                   Text="当前用户" />
                        <TextBlock FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Amber600Brush}"
                                   Margin="0,8,0,0"
                                   Text="{Binding AppContext.CurrentUserDisplayName}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick links -->
            <Border Style="{StaticResource CardStyle}"
                    Margin="0,24,0,0">
                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Gray900Brush}"
                               Text="功能导航" />
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource Green50Brush}"
                                CornerRadius="8"
                                Padding="16,14"
                                Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock FontSize="20" Text="🏥" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Green800Brush}"
                                           Text="院区管理" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource Gray500Brush}"
                                           Text="维护院区基础信息" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{StaticResource BlueSubtleBrush}"
                                CornerRadius="8"
                                Padding="16,14"
                                Margin="8,0,8,0">
                            <StackPanel>
                                <TextBlock FontSize="20" Text="📋" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BlueDeepBrush}"
                                           Text="挂号工作台" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource Gray500Brush}"
                                           Text="患者挂号与登记" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource Red50Brush}"
                                CornerRadius="8"
                                Padding="16,14"
                                Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock FontSize="20" Text="⚙️" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Red800Brush}"
                                           Text="系统设置" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource Gray500Brush}"
                                           Text="系统参数配置" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
