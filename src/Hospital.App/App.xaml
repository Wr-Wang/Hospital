<Application x:Class="Hospital.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Hospital.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Global converters -->
            <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:BoolToInverseConverter x:Key="BoolToInverseConverter" />
            <!-- ================================================================== -->
            <!-- DESIGN TOKENS — 遵循 DESIGN.md 色板定义                          -->
            <!-- ================================================================== -->

            <!-- Primary palette — Teal (医疗青绿) -->
            <SolidColorBrush x:Key="BlueDeepBrush" Color="#0F766E" />
            <SolidColorBrush x:Key="BluePrimaryBrush" Color="#14B8A6" />
            <SolidColorBrush x:Key="BlueHoverBrush" Color="#0D9488" />
            <SolidColorBrush x:Key="BlueLightBrush" Color="#2DD4BF" />
            <SolidColorBrush x:Key="BlueTintBrush" Color="#99F6E4" />
            <SolidColorBrush x:Key="BlueSubtleBrush" Color="#CCFBF1" />
            <SolidColorBrush x:Key="BlueAccentBrush" Color="#CCFBF1" />

            <!-- Neutral palette -->
            <SolidColorBrush x:Key="Gray900Brush" Color="#111827" />
            <SolidColorBrush x:Key="Gray700Brush" Color="#374151" />
            <SolidColorBrush x:Key="Gray500Brush" Color="#6B7280" />
            <SolidColorBrush x:Key="Gray400Brush" Color="#9CA3AF" />
            <SolidColorBrush x:Key="Gray300Brush" Color="#D1D5DB" />
            <SolidColorBrush x:Key="Gray200Brush" Color="#E5E7EB" />
            <SolidColorBrush x:Key="Gray100Brush" Color="#F3F4F6" />
            <SolidColorBrush x:Key="Gray50Brush" Color="#F0F2F5" />
            <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF" />

            <!-- Semantic palette -->
            <SolidColorBrush x:Key="Green600Brush" Color="#059669" />
            <SolidColorBrush x:Key="Green200Brush" Color="#A7F3D0" />
            <SolidColorBrush x:Key="Green50Brush" Color="#F0FDF4" />
            <SolidColorBrush x:Key="Green800Brush" Color="#166534" />
            <SolidColorBrush x:Key="Amber600Brush" Color="#D97706" />
            <SolidColorBrush x:Key="Red700Brush" Color="#B91C1C" />
            <SolidColorBrush x:Key="Red50Brush" Color="#FEF2F2" />
            <SolidColorBrush x:Key="Red200Brush" Color="#FECACA" />
            <SolidColorBrush x:Key="Red800Brush" Color="#991B1B" />

            <!-- Navigation specific -->
            <SolidColorBrush x:Key="NavTextBrush" Color="#CCFBF1" />
            <SolidColorBrush x:Key="NavTextSelectedBrush" Color="#FFFFFF" />

            <!-- ================================================================== -->
            <!-- SHARED EFFECTS                                                      -->
            <!-- ================================================================== -->

            <DropShadowEffect x:Key="CardShadowEffect"
                              BlurRadius="24"
                              Direction="270"
                              Opacity="0.12"
                              ShadowDepth="4"
                              Color="#000000" />

            <!-- ================================================================== -->
            <!-- SHARED STYLES                                                       -->
            <!-- ================================================================== -->

            <!-- Form label -->
            <Style x:Key="FormLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{StaticResource Gray700Brush}" />
                <Setter Property="Margin" Value="0,0,0,6" />
                <Setter Property="FontWeight" Value="Medium" />
            </Style>

            <!-- Text input -->
            <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
                <Setter Property="Height" Value="38" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="BorderBrush" Value="{StaticResource Gray300Brush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
                <Setter Property="Foreground" Value="{StaticResource Gray900Brush}" />
                <Setter Property="MinWidth" Value="300" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource Gray400Brush}" />
                    </Trigger>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BluePrimaryBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Password input -->
            <Style x:Key="FormPasswordBoxStyle" TargetType="PasswordBox">
                <Setter Property="Height" Value="38" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="BorderBrush" Value="{StaticResource Gray300Brush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
                <Setter Property="MinWidth" Value="300" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource Gray400Brush}" />
                    </Trigger>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BluePrimaryBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Primary button -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="40" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Background" Value="{StaticResource BluePrimaryBrush}" />
                <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"
                                                  SnapsToDevicePixels="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource BlueHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource BlueDeepBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource BlueTintBrush}" />
                                    <Setter Property="Cursor" Value="Arrow" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Secondary button -->
            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="40" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
                <Setter Property="Foreground" Value="{StaticResource Gray700Brush}" />
                <Setter Property="BorderBrush" Value="{StaticResource Gray300Brush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"
                                                  SnapsToDevicePixels="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Gray100Brush}" />
                                    <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Gray400Brush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200Brush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Error banner -->
            <Style x:Key="ErrorBannerStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Red50Brush}" />
                <Setter Property="BorderBrush" Value="{StaticResource Red200Brush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="10,8" />
            </Style>

            <!-- Card -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="24,20" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
